{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@styles/*": ["src/styles/*"],
      "@components/*": ["src/components/*"],
      "@layouts/*": ["src/layouts/*"],
      "@config/*": ["src/config/*"],
      "@content/*": ["src/content/*"],
      "@hub/*": ["src/hub/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "exclude": ["dist", "node_modules", "comma_agents_repo", "hub_repo"]
}
