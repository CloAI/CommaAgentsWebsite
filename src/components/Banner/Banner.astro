---
import { markdownify } from "@utils/markdown";

interface BannerData {
  title: string;
  content: string;
  image: string;
  button: {
    label: string;
    link: string;
    enable: boolean;
  };
}

interface Props {
  banner: BannerData;
}

const { banner } = Astro.props;
const { title, content, image, button } = banner;
---

<section class="banner section">
  <div class="container">
    <div class="bannerInner">
      <div class="bannerContent">
        <h1 set:html={markdownify(title)} />
        <p set:html={markdownify(content)} />
        {
          button.enable && button.label && (
            <a class="bannerButton" href={button.link}>
              {button.label}
            </a>
          )
        }
      </div>
      <div class="bannerImage">
        <img src={image} alt={title} loading="eager" />
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @use "styles/tokens" as *;
  @use "styles/mixins" as *;
  @use "styles/breakpoints" as *;

  .banner {
    padding-block: $spacing_3xl;

    @include breakpoint_lg {
      padding-block: 120px;
    }

    .bannerInner {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: $spacing_3xl;

      @include breakpoint_lg {
        flex-direction: row;
        justify-content: space-between;
        gap: $spacing_2xl;
      }
    }

    .bannerContent {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: $spacing_lg;
      text-align: center;
      max-width: 560px;

      @include breakpoint_lg {
        flex: 1;
        align-items: flex-start;
        text-align: left;
      }

      h1 {
        font-size: $font_h1 * 0.92;

        @include breakpoint_md {
          font-size: $font_h1 * 1.15;
        }
      }

      p {
        color: $color_text_muted;
        font-size: 1.125rem;
        max-width: 48ch;
      }
    }

    .bannerButton {
      @include button;
      margin-top: $spacing_sm;
      background-color: $color_accent;
      color: #fff;

      &:hover {
        background-color: $color_accent_hover;
      }
    }

    .bannerImage {
      @include flex_center;

      @include breakpoint_lg {
        flex: 1;
      }

      img {
        width: 100%;
        max-width: 360px;
        object-fit: contain;
      }
    }
  }
</style>
