---
import config from "@config/config.json";

const { logo, logo_text, logo_width, logo_height, title } = config.site;
---

<a href="/" class="logo" aria-label={title}>
  <img
    src={logo}
    alt={title}
    width={logo_width}
    height={logo_height}
    loading="eager"
  />
  <span class="logoText">{logo_text}</span>
</a>

<style lang="scss">
  @use "styles/tokens" as *;

  .logo {
    display: inline-flex;
    align-items: center;
    gap: $spacing_sm;

    img {
      width: 40px;
      height: 40px;
      object-fit: contain;
    }

    .logoText {
      font-family: $font_secondary;
      font-weight: $font_weight_bold;
      font-size: $font_h5;
      color: $color_text;
    }
  }
</style>
