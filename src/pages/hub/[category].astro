---
import PageHeader from "@components/PageHeader/PageHeader.astro";
import registry from "../../../hub_repo/registry.json";
import Base from "@layouts/Base.astro";
import { getCollection, type CollectionEntry } from "astro:content";
import type {
  HubArtifactKind,
  HubPackage,
  HubRegistryArtifact,
} from "@hub/hub.types";
import { getArtifactUrl, getHubArtifacts } from "@hub/hub.utils";

export async function getStaticPaths() {
  const categories = (await getCollection("hub")).filter(
    (entry) => entry.slug !== "-index",
  );

  return categories.map((entry) => ({
    params: { category: entry.data.name ?? entry.slug },
    props: {
      entry,
      artifacts: getHubArtifacts(
        registry,
        (entry.data.name ?? entry.slug) as HubArtifactKind,
      ),
    },
  }));
}

interface Props {
  entry: CollectionEntry<"hub">;
  artifacts: ReadonlyArray<{
    hubPackage: HubPackage;
    artifact: HubRegistryArtifact;
  }>;
}

const { entry, artifacts } = Astro.props as Props;
const { title, excerpt } = entry.data;
const category = (entry.data.name ?? entry.slug) as HubArtifactKind;
---

<Base title={`${title} · Comma Agents Hub`} description={excerpt}>
  <PageHeader title={title} description={excerpt}>
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/hub">Hub</a>
      <span>/</span>
      <span>{title}</span>
    </nav>
  </PageHeader>

  <section class="section">
    <div class="container">
      {
        artifacts.length > 0 ? (
          <div class="artifactGrid">
            {artifacts.map(({ hubPackage, artifact }) => (
              <a
                class="artifactCard"
                href={getArtifactUrl(category, hubPackage.name, artifact.id)}
              >
                <div class="artifactHeading">
                  <h2 class="h4">{artifact.id}</h2>
                  <span class="version">v{hubPackage.version}</span>
                </div>
                <p>{artifact.description ?? hubPackage.description}</p>
                <div class="artifactMeta">
                  <span>{hubPackage.name}</span>
                  <span>View details →</span>
                </div>
              </a>
            ))}
          </div>
        ) : (
          <div class="emptyState">
            <h2 class="h4">No published {title.toLowerCase()}</h2>
            <p>
              Published Hub packages will appear here after the registry is
              updated.
            </p>
          </div>
        )
      }
    </div>
  </section>
</Base>

<style lang="scss">
  @use "styles/tokens" as *;
  @use "styles/breakpoints" as *;

  .breadcrumb {
    display: inline-flex;
    align-items: center;
    gap: $spacing_sm;
    padding: $spacing_xs $spacing_md;
    border-radius: $radius_full;
    background-color: $color_surface;
    color: $color_text_muted;
    font-size: 0.9rem;

    a:hover {
      color: $color_accent;
    }
  }

  .artifactGrid {
    display: grid;
    grid-template-columns: 1fr;
    gap: $spacing_lg;

    @include breakpoint_md {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .artifactCard,
  .emptyState {
    display: flex;
    flex-direction: column;
    gap: $spacing_md;
    padding: $spacing_xl;
    background-color: $color_surface;
    border: 1px solid $color_border;
    border-radius: $radius_lg;
  }

  .artifactCard {
    transition:
      border-color 0.2s ease,
      background-color 0.2s ease;

    &:hover {
      border-color: $color_border_strong;
      background-color: $color_surface_alt;
    }

    .artifactHeading,
    .artifactMeta {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: $spacing_md;
    }

    .version {
      padding: $spacing_xs $spacing_sm;
      border-radius: $radius_full;
      background-color: $color_accent_soft;
      color: $color_accent;
      font-size: 0.85rem;
      font-weight: $font_weight_semibold;
    }

    .artifactMeta {
      margin-top: auto;
      color: $color_text_muted;
      font-size: 0.9rem;
    }

    p {
      color: $color_text_muted;
    }
  }

  .emptyState {
    align-items: center;
    text-align: center;

    p {
      color: $color_text_muted;
    }
  }
</style>
